[Unit]
Description=OmniGraph daily KOL Layer-1 classify (5 topics)
After=network-online.target omnigraph-vertex-proxy.service
Wants=network-online.target omnigraph-vertex-proxy.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/OmniGraph-Vault
EnvironmentFile=/root/.hermes/.env
ExecStart=/root/OmniGraph-Vault/venv-aim1/bin/python /root/OmniGraph-Vault/batch_classify_kol.py --topic Agent --topic LLM --topic RAG --topic NLP --topic CV --min-depth 2
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
