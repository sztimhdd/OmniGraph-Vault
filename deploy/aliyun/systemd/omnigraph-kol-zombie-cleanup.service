[Unit]
Description=OmniGraph kol zombie cleanup (pre-scan health check)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/OmniGraph-Vault
EnvironmentFile=/root/.hermes/.env
ExecStart=/root/OmniGraph-Vault/venv-aim1/bin/python /root/OmniGraph-Vault/scripts/clean_lightrag_zombies.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
