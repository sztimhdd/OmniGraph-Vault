[Unit]
Description=OmniGraph reconcile ingestions (bidirectional)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/OmniGraph-Vault
EnvironmentFile=/root/.hermes/.env
ExecStart=/root/OmniGraph-Vault/venv-aim1/bin/python /root/OmniGraph-Vault/scripts/reconcile_ingestions.py --auto-patch
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
