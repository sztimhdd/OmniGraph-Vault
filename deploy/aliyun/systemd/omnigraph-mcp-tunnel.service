[Unit]
Description=OmniGraph SSH tunnel: Aliyun localhost:8931 -> Hermes Playwright MCP (WeChat scrape fallback)
After=network-online.target
Wants=network-online.target
# StartLimitIntervalSec is a [Unit] directive (systemd >=v230); it was silently
# ignored in [Service]. =0 DISABLES the start rate limiter (retry forever) so the
# tunnel self-heals within RestartSec of Hermes coming back — NOT a limit.
# RestartSec=300 (was 10) cuts a Hermes-down flood from ~8640/day to ~288/day (30x)
# without a sticky failed-state that leaves the WeChat-scrape #3 fallback dead.
StartLimitIntervalSec=0

[Service]
Type=simple
User=root
ExecStart=/usr/bin/ssh -N -T \
  -o ConnectTimeout=15 \
  -o ExitOnForwardFailure=yes \
  -o ServerAliveInterval=30 \
  -o ServerAliveCountMax=3 \
  -o BatchMode=yes \
  -o StrictHostKeyChecking=accept-new \
  -L 127.0.0.1:8931:localhost:8931 -L 127.0.0.1:9222:localhost:9222 -L 127.0.0.1:58932:localhost:58932 \
  hermes
Restart=always
RestartSec=300

[Install]
WantedBy=multi-user.target
