# OmniGraph-Vault Environment Template
# Copy this to ~/.hermes/.env and fill in your values

# Required: Google Gemini API key
# Get from: https://aistudio.google.com/apikey
# This key is used for:
#   - LLM generation (text synthesis, entity extraction)
#   - Vision API (image description)
#   - Embeddings API (vector encoding for knowledge graph)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Apify token for primary WeChat scraping
# Get from: https://apify.com (sign up, create API token)
# If not set, ingest_wechat.py falls back to local Chrome DevTools Protocol
# Remove this line to disable Apify and use CDP only
APIFY_TOKEN=your_apify_token_here

# Optional: Chrome DevTools Protocol endpoint
# Default: http://localhost:9223 (local Edge/Chrome with --remote-debugging-port=9223)
# For remote testing with Playwright MCP: http://host:port/mcp (e.g. http://ohca.ddns.net:58931/mcp)
# The /mcp suffix auto-triggers MCP client mode instead of native CDP connection
CDP_URL=http://localhost:9223
