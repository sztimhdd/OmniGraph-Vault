# OmniGraph-Vault environment template.
# Copy to ~/.hermes/.env and fill in real values.

# =========================
# Gemini API — required
# =========================

# Primary key, scoped to OmniGraph-Vault.
OMNIGRAPH_GEMINI_KEY=

# Optional: comma-separated pool for multi-account rotation.
# Only useful across different Google accounts / GCP projects —
# Gemini quotas are per-project, not per-key.
OMNIGRAPH_GEMINI_KEYS=

# Legacy fallback — still works if OMNIGRAPH_GEMINI_KEY is unset.
# For new deployments, prefer OMNIGRAPH_GEMINI_KEY above.
GEMINI_API_KEY=

# Legacy backup — folded into the rotation pool automatically if set alongside primary.
GEMINI_API_KEY_BACKUP=

# =========================
# DeepSeek API — required (Phase 5)
# =========================
# Phase 5 Plan 05-00c imports lib.llm_deepseek eagerly, which requires
# DEEPSEEK_API_KEY to be set at import time. Gemini-only workloads that
# `import lib` will crash without this variable (Hermes FLAG 2 from
# 07-REVIEW-HERMES-WAVES-2-3.md §6). Set even if only running Gemini scripts.
DEEPSEEK_API_KEY=

# =========================
# Model names (NOT environment-overridable — Amendment 1)
# =========================
# Model constants are pure strings in lib/models.py:
#   INGESTION_LLM     = "gemini-2.5-flash-lite"
#   VISION_LLM        = "gemini-2.5-flash-lite"
#   SYNTHESIS_LLM     = "gemini-2.5-flash-lite"
#   EMBEDDING_MODEL   = "gemini-embedding-2"       # D-10: production default
#   GITHUB_INGEST_LLM = "gemini-3.1-flash-lite-preview"  # D-05: preview preserved
# Rollback path is `git revert && push && pull-on-remote`.

# =========================
# Optional: per-model RPM caps on paid tier (D-08 retained — env-overridable)
# Default values from lib/models.py RATE_LIMITS_RPM (free-tier limits).
# =========================
# OMNIGRAPH_RPM_GEMINI_2_5_FLASH_LITE=300
# OMNIGRAPH_RPM_GEMINI_EMBEDDING_2=1500

# =========================
# Scraping (optional)
# =========================
APIFY_TOKEN=
FIRECRAWL_API_KEY=
CDP_URL=http://localhost:9223
