
# --- API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here
APIFY_TOKEN=your_apify_token_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# --- Configuration ---
# CDP_URL: browser endpoint for Playwright scraping fallback in ingest_wechat.py
# Local:  http://localhost:9223  (raw CDP WebSocket — works with connect_over_cdp)
#         Start Edge: msedge --remote-debugging-port=9223
# Remote: http://host:port/mcp   (Playwright MCP server — NOT compatible with connect_over_cdp)
#         Remote requires MCP client refactor in ingest_wechat.py before it can be used.
CDP_URL=http://localhost:9223
