
# --- API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here
APIFY_TOKEN=your_apify_token_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# --- Configuration ---
# CDP_URL: browser scraping fallback for ingest_wechat.py
# Production default — local Edge with remote debugging enabled:
#   msedge --remote-debugging-port=9223
#   CDP_URL=http://localhost:9223
#
# Local testing fallback — remote Playwright MCP server (when no local Edge available):
#   CDP_URL=http://host:port/mcp
#   NOTE: ingest_wechat.py currently uses connect_over_cdp() (local only).
#         MCP client support for this path is not yet implemented.
CDP_URL=http://localhost:9223
