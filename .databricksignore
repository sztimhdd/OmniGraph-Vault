# Project-root .databricksignore for OmniGraph-Vault Databricks Apps deploy.
# Used by `databricks sync --exclude-from .databricksignore`.
#
# Deploy contract: ONLY databricks-deploy/* + kb/* (synced separately into
# databricks-deploy/kb/ via 2-pass sync) + minimal config files reach the
# workspace. Everything else is dev-only OR runtime-side noise.

# === Re-include kb subtrees that .gitignore would otherwise eat ===
# .gitignore line `data/*` (project-root rule for runtime metric JSON files)
# also matches `kb/data/*` because `databricks sync` honors .gitignore
# patterns AT ANY DEPTH inside the sync source. Without these negations,
# kb/data/article_query.py never reaches the workspace and `import kb.data`
# fails at app boot with ModuleNotFoundError.
!data/
!data/**

# kb/output/ is the SSG build output — gitignored (`kb/output/*` at root +
# `*` inside `kb/output/.gitignore`) but Databricks Apps deploy is the only
# tier that serves the static frontend (Aliyun uses Caddy; Databricks has
# no Caddy, so FastAPI-via-app_entry.py mounts kb/output/ at /).
!output/
!output/**

# databricks-deploy/_ssg/ is a deploy-time copy of kb/output/ (Makefile pass-0
# rsyncs before pass-1 sync). It IS in .gitignore (regenerated artifact) but
# MUST land in workspace for app_entry.py to serve the SSG frontend.
!_ssg/
!_ssg/**
!databricks-deploy/_ssg/
!databricks-deploy/_ssg/**

