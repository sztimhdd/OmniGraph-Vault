
# Environment
.env
**/.env
**/.env.local
# Prevent committing .env backup files that may contain secrets
**/.env*.bak*
venv/
__pycache__/
*.egg-info/

# Personal Claude Code tooling (not project artifacts)
.claude/

# Local dev runtime — DB copy, LightRAG storage, images, logs, local .env
# Entirely off-repo to keep company-machine data confined to project folder
.dev-runtime/

# GSD orchestrator state — auto-regenerated, not project artifact
.planning/config.json

# Hermes session JSON dumps from query reproduction sessions (~600KB each)
docs/queries/hermes_session_*/
# …except: 2026-05-06 session is committed as Agentic-RAG-v1 milestone ground truth
!docs/queries/hermes_session_2026_05_06/

# Scratch / experimental work — never commit
.scratch/

# Playwright MCP runtime cache (per-call screenshots / traces, not source)
.playwright-mcp/

# Data (Crucial to ignore these!)
# Use data/* (not data/) so specific files can be un-ignored with ! below.
data/*
!data/karpathy_hn_2025.opml
# kb/data/ is a real Python module (article_query.py, lang_detect.py, migrations/)
# tracked by git — exempt it from the broad data/* rule above so `databricks sync`
# (which honors .gitignore at any depth inside the sync source) ships it.
!kb/data/
!kb/data/**
# But the `**` re-include above also rescues __pycache__/ from the global
# rule on line 5; re-exclude bytecode under kb/data/ so it stays out.
kb/data/**/__pycache__/
images/
lightrag_storage/
*.log

!*.md
!specs/
!Deploy.md
!README.md
!project_summary.md
entity_buffer/
canonical_map.json
canonical_map.json.tmp
entity_registry.json.tmp

# Local-only KOL config (contains WeChat credentials)
kol_config.py

# Release build artifacts
*.tar.gz

# Spider source copies (gitignored)
spiders/*.zip

# Binary archives
*.zip

# Knowledge Base build output (SSG-generated, not source)
# Pattern is `kb/output/*` (not `kb/output/`) so per-dir `kb/output/.gitignore`
# can be re-included via the negation below — same fix pattern as credentials/
# below. This lets the kb/output/ directory exist in git (via the .gitignore
# file itself) while excluding all SSG build artifacts.
kb/output/*
!kb/output/.gitignore

# Vertex AI service account keys — directory contents excluded, template tracked
# NOTE: pattern is `credentials/*` (not `credentials/`) because git cannot re-include
# a file whose parent directory is excluded by a dir-pattern. Using `credentials/*`
# excludes files inside the dir but allows the negation to keep the template tracked.
credentials/*
!credentials/vertex_ai_service_account_example.json

# databricks-deploy/ regenerated artifacts — NOT source.
# Makefile pass-0/0c copies these from project root each `make deploy`:
#   _ssg/  ← kb/output/                      (SSG output)
#   lib/, config.py, kg_synthesize.py ← project root
# `databricks sync` still picks them up via `.databricksignore` re-includes
# (`!_ssg/`, `!databricks-deploy/_ssg/**`); root-anchored excludes (`/lib/`)
# don't match nested `databricks-deploy/lib/`, so deploy contract is intact.
databricks-deploy/_ssg/
databricks-deploy/lib/
databricks-deploy/config.py
databricks-deploy/kg_synthesize.py

# Production-config backups (timestamped or *.production-backup) — local-only.
databricks-deploy/*.production-backup

# IDE personal settings — never project artifacts.
.vscode/
