
# Environment
.env
venv/
__pycache__/

# Personal Claude Code tooling (not project artifacts)
.claude/

# Local dev runtime — DB copy, LightRAG storage, images, logs, local .env
# Entirely off-repo to keep company-machine data confined to project folder
.dev-runtime/

# GSD orchestrator state — auto-regenerated, not project artifact
.planning/config.json

# Hermes session JSON dumps from query reproduction sessions (~600KB each)
docs/queries/hermes_session_*/
# …except: 2026-05-06 session is committed as Agentic-RAG-v1 milestone ground truth
!docs/queries/hermes_session_2026_05_06/

# Scratch / experimental work — never commit
.scratch/

# Data (Crucial to ignore these!)
# Use data/* (not data/) so specific files can be un-ignored with ! below.
data/*
!data/karpathy_hn_2025.opml
images/
lightrag_storage/
*.log

!*.md
!specs/
!Deploy.md
!README.md
!project_summary.md
entity_buffer/
canonical_map.json
canonical_map.json.tmp
entity_registry.json.tmp

# Local-only KOL config (contains WeChat credentials)
kol_config.py

# Release build artifacts
*.tar.gz

# Spider source copies (gitignored)
spiders/*.zip

# Binary archives
*.zip

# Knowledge Base build output (SSG-generated, not source)
kb/output/

# Vertex AI service account keys — directory contents excluded, template tracked
# NOTE: pattern is `credentials/*` (not `credentials/`) because git cannot re-include
# a file whose parent directory is excluded by a dir-pattern. Using `credentials/*`
# excludes files inside the dir but allows the negation to keep the template tracked.
credentials/*
!credentials/vertex_ai_service_account_example.json
